{
  "name": "quest-failed-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Dev-tooling only. The game itself loads Phaser via CDN and ships as static files; this package.json exists to manage Node-side baking/build scripts under tools/.",
  "scripts": {
    "verify-docs": "node tools/verify-docs.mjs",
    "verify-docs:fix": "node tools/verify-docs.mjs --fix",
    "lint-content": "node tools/lint-content.mjs",
    "lint-content:strict": "node tools/lint-content.mjs --strict",
    "sim": "node tools/sim/harness.mjs game",
    "sim:balance": "node tools/sim/balance.mjs",
    "sim:pacts": "node tools/sim/pactsweep.mjs",
    "sim:soak": "node tools/sim/soak.mjs",
    "lpc:survey": "node tools/lpc-survey.mjs",
    "lpc:validate": "node tools/lpc-validate-pools.mjs",
    "lpc:bake": "node tools/bake-lpc-variants.mjs"
  },
  "dependencies": {
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "ffmpeg-static": "^5.3.0"
  }
}
